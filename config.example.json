{
    "data": {
        "source": "pytdx",
        "start_date": "20240101",
        "end_date": "auto",
        "adjust": "hfq",
        "cache_dir": "data/cache",
        "scan_cache_dir": "data/scan_cache",
        "annotations_file": "data/annotations.csv"
    },
    "label": {
        "mode": "binary",
        "pre_days": 10
    },
    "factor": {
        "categories": ["trend", "momentum", "volatility", "volume_price", "pattern", "statistics"]
    },
    "model": {
        "algorithm": "lightgbm",
        "params": {
            "objective": "binary",
            "metric": "auc",
            "boosting_type": "gbdt",
            "num_leaves": 31,
            "learning_rate": 0.02,
            "feature_fraction": 0.8,
            "bagging_fraction": 0.8,
            "bagging_freq": 5,
            "lambda_l1": 1.0,
            "lambda_l2": 1.0,
            "scale_pos_weight": 5,
            "min_child_samples": 20,
            "verbose": -1
        },
        "train_ratio": 0.7,
        "early_stopping_rounds": 50,
        "num_boost_round": 500
    },
    "signal": {
        "buy_threshold": 0.45,
        "sell_threshold": 0.30,
        "consecutive_days": 2,
        "min_holding_days": 5
    },
    "scan": {
        "top_n": 50,
        "upcoming_n": 30,
        "download_workers": 8
    }
}
